# ============================================================
# PLATFORMA COMPLIANCE — ZMIENNE SRODOWISKOWE
# ============================================================
# Skopiuj ten plik jako .env i uzupelnij wartosci
# NIGDY nie commituj .env do repozytorium!
# ============================================================

# -------------------- BAZA DANYCH --------------------
DATABASE_URL="postgresql://compliance_user:compliance_pass@localhost:5432/compliance_db?schema=public"

# -------------------- NEXTAUTH.JS --------------------
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# -------------------- GOOGLE OAUTH --------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------------------- OPENAI API --------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# -------------------- STRIPE --------------------
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -------------------- APP CONFIG --------------------
NODE_ENV="development"
PORT="3000"
MAX_POST_LENGTH="5000"
TRIAL_DAYS="14"
